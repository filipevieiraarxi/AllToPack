<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="product_template_rollover_hinged_lid" model="product.template">
            <field name="name">Caixa Rollover Hinged Lid</field>
            <field name="type">consu</field>
            <field name="sale_ok" eval="True"/>
            <field name="is_published" eval="True"/>
            <field name="list_price">1.0</field>
            <field name="description_sale">
                Caixa articulada Rollover Hinged Lid. Configure as dimensões
                e exporte o dieline personalizado para produção.
            </field>
            <field name="box_type">rollover_hinged_lid</field>
            <field name="box_l">100.0</field>
            <field name="box_w">150.0</field>
            <field name="box_h">40.0</field>
            <field name="box_dieline_svg_fname">rollover_hinged_lid.svg</field>
            <field name="box_dieline_svg"></field>
        </record>

        <record id="product_template_rsc_regular_slotted" model="product.template">
            <field name="name">RSC Regular Slotted Container</field>
            <field name="type">consu</field>
            <field name="sale_ok" eval="True"/>
            <field name="is_published" eval="True"/>
            <field name="list_price">1.0</field>
            <field name="description_sale">
                RSC — Regular Slotted Container. Caixa de cartão standard com
                abas do mesmo comprimento. Configure as dimensões e exporte o dieline.
            </field>
            <field name="box_type">rsc_regular_slotted</field>
            <field name="box_l">290.0</field>
            <field name="box_w">200.0</field>
            <field name="box_h">150.0</field>
            <field name="box_dieline_svg_fname">rsc_regular_slotted.svg</field>
            <field name="box_dieline_svg"></field>
        </record>

    </data>
</odoo>
