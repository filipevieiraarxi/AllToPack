<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Adiciona tab "Dieline" no formulário de produto (backend) -->
    <record id="product_template_form_view_dieline" model="ir.ui.view">
        <field name="name">product.template.form.dieline</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Dieline 3D" name="dieline_3d">
                    <group>
                        <group string="Tipo e Dimensões">
                            <field name="box_type" string="Tipo de Caixa (FEFCO)"/>
                            <field name="box_l" string="Comprimento L (mm)"/>
                            <field name="box_w" string="Largura W (mm)"/>
                            <field name="box_h" string="Altura H (mm)"/>
                        </group>
                        <group string="Imagens do Card">
                            <field name="card_image_normal" widget="binary"
                                   filename="card_image_normal_fname"
                                   string="Imagem normal"/>
                            <field name="card_image_normal_fname" invisible="1"/>
                            <field name="card_image_hover" widget="binary"
                                   filename="card_image_hover_fname"
                                   string="Imagem hover"/>
                            <field name="card_image_hover_fname" invisible="1"/>
                        </group>
                        <group string="SVG de Dieline" colspan="2">
                            <field name="box_dieline_svg" widget="binary"
                                   filename="box_dieline_svg_fname"
                                   string="Ficheiro SVG"/>
                            <field name="box_dieline_svg_fname" string="Nome do ficheiro"/>
                            <div class="text-muted small" colspan="2">
                                Formato B: SVG com &lt;g id="root_group"&gt; contendo linhas coloridas.
                                Vermelho (rgb(255,0,0)) = corte · Azul (rgb(0,0,255)) = vinco · Verde = dimensões (ignorado).
                                O motor 3D constrói a geometria 3D automaticamente via DCEL.
                            </div>
                        </group>
                    </group>
                    <div class="mt-2">
                        <button name="action_open_dieline_3d" type="object"
                                class="btn btn-sm btn-outline-primary"
                                icon="fa-cube" string="Ver Dieline 3D"/>
                    </div>
                </page>
            </notebook>
        </field>
    </record>

</odoo>
