<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="dieline_page" name="Dieline Engine">
        <t t-call="website.layout">
            <t t-set="title">
                <t t-if="product">Dieline — <t t-esc="product.name"/> — AllToPack</t>
                <t t-else="">Configurador de Caixas — AllToPack</t>
            </t>
            <t t-set="head">
                <link rel="stylesheet" href="/alltoppack_website/static/src/css/dieline.css"/>
            </t>

            <div id="wrap" class="atp-dieline-wrap">
                <div class="atp-dl-page">

                    <!-- ── BODY: viewer (esquerda) + sidebar cards (direita) ── -->
                    <div class="atp-dl-body">

                        <!-- VIEWER -->
                        <div class="atp-dl-viewer" id="atp-dl-viewer">
                            <!-- 3D canvas -->
                            <canvas id="canvas3d" class="atp-dl-canvas3d"/>
                            <!-- 2D dieline SVG (hidden by default) -->
                            <div id="atp-2d-view" class="atp-dl-2dview" style="display:none">
                                <img id="atp-2d-img" alt="Dieline 2D"/>
                            </div>
                            <!-- 2D Logo compositor (hidden by default) -->
                            <div id="atp-logo2d-view" class="atp-dl-logo2d-view" style="display:none">
                                <div class="atp-logo2d-toolbar">
                                    <button id="logo2d-side-front" class="atp-ctrl active" title="Exterior da caixa (face imprimível)">
                                        <i class="fa fa-square-o me-1"/>Frente
                                    </button>
                                    <button id="logo2d-side-back" class="atp-ctrl" title="Interior da caixa">
                                        <i class="fa fa-square me-1"/>Verso
                                    </button>
                                    <span class="atp-ctrl-sep" style="margin:0 6px"/>
                                    <button id="logo2d-zoom-in" class="atp-ctrl" title="Zoom +"><i class="fa fa-search-plus"/></button>
                                    <button id="logo2d-zoom-out" class="atp-ctrl" title="Zoom −"><i class="fa fa-search-minus"/></button>
                                    <button id="logo2d-zoom-fit" class="atp-ctrl" title="Ajustar ao ecrã"><i class="fa fa-expand"/></button>
                                </div>
                                <div class="atp-logo2d-canvas-wrap" id="atp-logo2d-wrap">
                                    <canvas id="canvas2dlogo" class="atp-logo2d-canvas"/>
                                </div>
                                <span class="atp-dl-viewer-hint" id="logo2d-hint">
                                    arrastar o logo para reposicionar · scroll para zoom
                                </span>
                            </div>
                            <!-- Hint flutuante -->
                            <span id="atp-viewer-hint" class="atp-dl-viewer-hint">
                                arrastar para rodar · scroll para zoom
                            </span>
                            <!-- Nome do produto -->
                            <t t-if="product">
                                <span class="atp-dl-viewer-title">
                                    <t t-esc="product.name"/>
                                </span>
                            </t>
                        </div>

                        <!-- RIGHT SIDEBAR — collapsible cards -->
                        <div class="atp-dl-sidebar">

                            <!-- CARD: Dimensions (open by default) -->
                            <div class="atp-scard atp-scard--open">
                                <button type="button" class="atp-scard-header" data-atp-toggle="1">
                                    <i class="fa fa-arrows-alt"/>
                                    <span>Dimensions</span>
                                    <i class="fa fa-chevron-up atp-scard-chevron"/>
                                </button>
                                <div class="atp-scard-body">
                                    <div class="atp-dim-grid">
                                        <div class="atp-dim-field">
                                            <label>Length</label>
                                            <input type="number" id="iL" t-att-value="box_l" min="40" max="600"/>
                                            <span class="atp-dim-unit">mm</span>
                                        </div>
                                        <div class="atp-dim-field">
                                            <label>Width</label>
                                            <input type="number" id="iW" t-att-value="box_w" min="30" max="600"/>
                                            <span class="atp-dim-unit">mm</span>
                                        </div>
                                        <div class="atp-dim-field">
                                            <label>Height</label>
                                            <input type="number" id="iH" t-att-value="box_h" min="30" max="600"/>
                                            <span class="atp-dim-unit">mm</span>
                                        </div>
                                    </div>
                                    <button id="btnApply" class="atp-scard-btn mt-3 w-100">
                                        <i class="fa fa-refresh me-1"/>Update 3D
                                    </button>
                                    <span id="infoBlank" class="atp-scard-info mt-1"/>
                                </div>
                            </div>

                            <!-- CARD: Material -->
                            <div class="atp-scard">
                                <button type="button" class="atp-scard-header" data-atp-toggle="1">
                                    <i class="fa fa-cube"/>
                                    <span>Material</span>
                                    <i class="fa fa-chevron-down atp-scard-chevron"/>
                                </button>
                                <div class="atp-scard-body" style="display:none">
                                    <div class="atp-radio-grid">
                                        <label class="atp-radio-tile">
                                            <input type="radio" name="material" value="e_flute" checked="True"/>
                                            <span class="atp-radio-tile-inner">
                                                <strong>E-Flute</strong>
                                                <small>1.5 mm</small>
                                            </span>
                                        </label>
                                        <label class="atp-radio-tile">
                                            <input type="radio" name="material" value="b_flute"/>
                                            <span class="atp-radio-tile-inner">
                                                <strong>B-Flute</strong>
                                                <small>3 mm</small>
                                            </span>
                                        </label>
                                        <label class="atp-radio-tile">
                                            <input type="radio" name="material" value="bc_flute"/>
                                            <span class="atp-radio-tile-inner">
                                                <strong>BC-Flute</strong>
                                                <small>6 mm</small>
                                            </span>
                                        </label>
                                        <label class="atp-radio-tile">
                                            <input type="radio" name="material" value="solid"/>
                                            <span class="atp-radio-tile-inner">
                                                <strong>Solid Board</strong>
                                                <small>0.5 mm</small>
                                            </span>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- CARD: Quantity -->
                            <div class="atp-scard">
                                <button type="button" class="atp-scard-header" data-atp-toggle="1">
                                    <i class="fa fa-cubes"/>
                                    <span>Quantity and design variants</span>
                                    <span class="atp-scard-summary" id="qty-summary">500 pcs · 1 variant</span>
                                    <i class="fa fa-chevron-down atp-scard-chevron"/>
                                </button>
                                <div class="atp-scard-body" style="display:none">
                                    <!-- Input row -->
                                    <div class="atp-qty-input-row">
                                        <div class="atp-qty-field">
                                            <span class="atp-qty-range">min 1 → max 1 Mil</span>
                                            <div class="atp-qty-box">
                                                <input id="acc-qty-input" type="number" value="500" min="1" step="1" class="atp-qty-main-input"/>
                                                <span class="atp-qty-pcs">pcs</span>
                                            </div>
                                        </div>
                                        <div class="atp-qty-field atp-qty-field--grow">
                                            <span class="atp-qty-range">Design variants</span>
                                            <div class="atp-qty-box">
                                                <input id="acc-variants-input" type="number" value="1" min="1" max="10" class="atp-qty-main-input"/>
                                            </div>
                                        </div>
                                    </div>
                                    <!-- Price tiers -->
                                    <div class="atp-tier-row" id="atp-tier-row">
                                        <button type="button" class="atp-tier" data-qty="1"><span class="atp-tier-qty">1</span><span class="atp-tier-price">€23.49</span></button>
                                        <button type="button" class="atp-tier atp-tier--active" data-qty="100"><span class="atp-tier-qty">100</span><span class="atp-tier-price">€2.01</span></button>
                                        <button type="button" class="atp-tier" data-qty="500"><span class="atp-tier-qty">500</span><span class="atp-tier-price">€1.20</span></button>
                                        <button type="button" class="atp-tier" data-qty="1000"><span class="atp-tier-qty">1,000</span><span class="atp-tier-price">€0.56</span></button>
                                        <button type="button" class="atp-tier" data-qty="5000"><span class="atp-tier-qty">5,000</span><span class="atp-tier-price">€0.35</span></button>
                                        <t t-if="not request.env.user._is_public()">
                                            <button type="button" class="atp-tier" data-qty="25000"><span class="atp-tier-qty">25,000</span><span class="atp-tier-price">€0.17</span></button>
                                        </t>
                                        <t t-else="">
                                            <a t-attf-href="/web/login?redirect={{request.httprequest.full_path}}"
                                               class="atp-tier atp-tier--locked" title="Login to unlock this price">
                                                <span class="atp-tier-qty">25,000</span>
                                                <span class="atp-tier-price atp-tier-price--blur">€0.17</span>
                                                <i class="fa fa-lock atp-tier-lock"/>
                                            </a>
                                        </t>
                                    </div>
                                    <label class="atp-check-row mt-2">
                                        <input type="checkbox" name="variant" value="print_both"/>
                                        <span>Print both sides</span>
                                    </label>
                                </div>
                            </div>

                            <!-- CARD: Finishes -->
                            <div class="atp-scard">
                                <button type="button" class="atp-scard-header" data-atp-toggle="1">
                                    <i class="fa fa-magic"/>
                                    <span>Special Finishes</span>
                                    <i class="fa fa-chevron-down atp-scard-chevron"/>
                                </button>
                                <div class="atp-scard-body" style="display:none">
                                    <label class="atp-check-row"><input type="checkbox" name="finish" value="gloss_laminate"/><span>Gloss laminate</span></label>
                                    <label class="atp-check-row"><input type="checkbox" name="finish" value="matte_laminate"/><span>Matte laminate</span></label>
                                    <label class="atp-check-row"><input type="checkbox" name="finish" value="spot_uv"/><span>Spot UV</span></label>
                                    <label class="atp-check-row"><input type="checkbox" name="finish" value="embossing"/><span>Embossing / Debossing</span></label>
                                    <label class="atp-check-row"><input type="checkbox" name="finish" value="hot_foil"/><span>Hot foil stamping</span></label>
                                </div>
                            </div>

                            <!-- CARD: Artwork -->
                            <div class="atp-scard" id="acc-upload">
                                <button type="button" class="atp-scard-header" data-atp-toggle="1">
                                    <i class="fa fa-paint-brush"/>
                                    <span>Artwork / Logo</span>
                                    <i class="fa fa-chevron-down atp-scard-chevron"/>
                                </button>
                                <div class="atp-scard-body" style="display:none">
                                    <!-- Pré-visualização e controlos do logo -->
                                    <div id="atp-artwork-panel">
                                        <img id="atp-artwork-preview" alt="preview"
                                             style="display:none;width:100%;border-radius:6px;margin:0 0 8px"/>
                                        <!-- Rotação -->
                                        <div id="atp-artwork-rot-row" class="atp-artwork-rot-row" style="display:none">
                                            <button id="atp-artwork-rot-ccw" class="atp-artwork-rot-btn" title="Rodar 90° CCW">
                                                <i class="fa fa-undo"/>
                                            </button>
                                            <span id="atp-artwork-rot-label" class="atp-artwork-rot-deg">0°</span>
                                            <button id="atp-artwork-rot-cw" class="atp-artwork-rot-btn" title="Rodar 90° CW">
                                                <i class="fa fa-repeat"/>
                                            </button>
                                        </div>
                                        <!-- Escala -->
                                        <div id="atp-artwork-scale-row" class="atp-artwork-rot-row" style="display:none">
                                            <button id="atp-artwork-scale-down" class="atp-artwork-rot-btn" title="Reduzir">
                                                <i class="fa fa-search-minus"/>
                                            </button>
                                            <span id="atp-artwork-scale-label" class="atp-artwork-rot-deg">80mm</span>
                                            <button id="atp-artwork-scale-up" class="atp-artwork-rot-btn" title="Aumentar">
                                                <i class="fa fa-search-plus"/>
                                            </button>
                                        </div>
                                        <!-- Hint: ir para 2D Logo -->
                                        <div id="atp-artwork-drag-hint" class="atp-scard-hint" style="display:none">
                                            <i class="fa fa-paint-brush me-1"/>Use a tab <strong>2D Logo</strong> para posicionar o logo no dieline.
                                        </div>
                                        <button id="atp-goto-logo2d" class="atp-scard-btn w-100 mb-2" style="display:none;background:#0f766e">
                                            <i class="fa fa-th me-1"/>Posicionar no Dieline
                                        </button>
                                        <button id="atp-artwork-remove" class="atp-scard-btn w-100 mb-1" style="display:none;background:#ef4444">
                                            <i class="fa fa-trash me-1"/>Remover logo
                                        </button>
                                    </div>
                                    <label class="atp-scard-btn w-100 text-center mb-1" for="fileArtwork">
                                        <i class="fa fa-folder-open me-1"/>Escolher imagem…
                                    </label>
                                    <input type="file" id="fileArtwork" accept="image/*" style="display:none"/>
                                    <span id="artworkName" class="atp-scard-info"/>
                                    <button id="atp-artwork-save" class="atp-scard-btn w-100 mt-2">
                                        <i class="fa fa-save me-1"/>Guardar Artwork
                                    </button>
                                    <span id="atp-artwork-save-msg" class="atp-scard-info atp-text-ok mt-1" style="display:none!important"/>
                                </div>
                            </div>

                            <!-- CARD: Delivery -->
                            <div class="atp-scard">
                                <button type="button" class="atp-scard-header" data-atp-toggle="1">
                                    <i class="fa fa-truck"/>
                                    <span>Manufacturing time</span>
                                    <i class="fa fa-chevron-down atp-scard-chevron"/>
                                </button>
                                <div class="atp-scard-body" style="display:none">
                                    <div class="atp-delivery-cols">
                                        <div class="atp-delivery-option atp-delivery-option--active">
                                            <i class="fa fa-truck atp-delivery-icon"/>
                                            <span class="atp-delivery-label">Standard</span>
                                            <span class="atp-delivery-date">~14 June</span>
                                        </div>
                                        <div class="atp-delivery-option">
                                            <i class="fa fa-bolt atp-delivery-icon"/>
                                            <span class="atp-delivery-label">Fast</span>
                                            <span class="atp-delivery-date">~11 June</span>
                                        </div>
                                        <div class="atp-delivery-option">
                                            <i class="fa fa-rocket atp-delivery-icon"/>
                                            <span class="atp-delivery-label">Special</span>
                                            <span class="atp-delivery-date">~8 June</span>
                                        </div>
                                    </div>
                                    <div class="atp-delivery-shipping">
                                        <i class="fa fa-globe me-2"/>
                                        Free shipping in 29 EU Countries
                                    </div>
                                </div>
                            </div>

                            <!-- CARD: Order (always visible, no toggle) -->
                            <div class="atp-scard atp-scard--order">
                                <t t-if="product and product_variant_id">
                                    <div class="atp-scard-body">
                                        <div class="atp-order-price">
                                            <div class="atp-order-total" id="atp-order-total">
                                                <t t-esc="'€{:,.2f}'.format(product_price * 500)"/>
                                            </div>
                                            <div class="atp-order-unit" id="atp-order-unit">
                                                <t t-esc="'€{:.4f}'.format(product_price)"/>
                                                <span class="atp-order-unit-sep"> × </span>
                                                <span id="atp-order-qty-label">500 pcs</span>
                                            </div>
                                        </div>
                                        <form id="atp-cart-form" action="/shop/cart/update" method="post">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                            <input type="hidden" name="product_id" t-att-value="product_variant_id"/>
                                            <input type="hidden" name="add_qty" id="cart-qty-input" value="500"/>
                                            <input type="hidden" name="dieline_config_id" id="cart-dieline-config-id" value=""/>
                                            <button type="submit" id="atp-btn-addcart" class="atp-btn-addcart w-100">
                                                <i class="fa fa-shopping-cart me-2"/>Add to cart
                                            </button>
                                        </form>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div class="atp-scard-body">
                                        <a href="/contactus" class="atp-btn-addcart w-100" style="text-decoration:none">
                                            <i class="fa fa-envelope me-2"/>Request a Quote
                                        </a>
                                    </div>
                                </t>
                            </div>

                        </div><!-- /sidebar -->
                    </div><!-- /body -->

                    <!-- ── CONTROL BAR (bottom center) ── -->
                    <div class="atp-dl-controls">
                        <!-- View toggle -->
                        <div class="atp-ctrl-group">
                            <button id="ctrl-3d" class="atp-ctrl active" title="Vista 3D">
                                <i class="fa fa-cube"/> 3D
                            </button>
                            <button id="ctrl-2d" class="atp-ctrl" title="Vista 2D — Dieline">
                                <i class="fa fa-th"/> 2D
                            </button>
                            <button id="ctrl-logo2d" class="atp-ctrl" title="Posicionar logo no dieline">
                                <i class="fa fa-paint-brush"/> 2D Logo
                            </button>
                        </div>

                        <div class="atp-ctrl-sep"/>

                        <!-- Animation -->
                        <div class="atp-ctrl-group">
                            <button id="ctrl-anim" class="atp-ctrl" title="Animar abertura/fecho">
                                <i class="fa fa-play" id="ctrl-anim-icon"/>
                            </button>
                            <input type="range" id="animSlider" min="0" max="100" value="0" class="atp-dl-slider" title="Posição da animação"/>
                            <span id="animPct" class="atp-dl-pct">0%</span>
                        </div>

                        <div class="atp-ctrl-sep"/>

                        <!-- Rotation + Zoom + Reset -->
                        <div class="atp-ctrl-group">
                            <button id="ctrl-rotate" class="atp-ctrl" title="Auto-rodar">
                                <i class="fa fa-refresh"/>
                            </button>
                            <button id="ctrl-zoom-in" class="atp-ctrl" title="Zoom +">
                                <i class="fa fa-plus"/>
                            </button>
                            <button id="ctrl-zoom-out" class="atp-ctrl" title="Zoom −">
                                <i class="fa fa-minus"/>
                            </button>
                            <button id="ctrl-reset" class="atp-ctrl" title="Repor vista">
                                <i class="fa fa-undo"/>
                            </button>
                        </div>
                    </div><!-- /controls -->

                </div><!-- /page -->
            </div><!-- /wrap -->

            <!-- Config injectada pelo controller -->
            <script>
                window.ATP_CONFIG = {
                    boxType: '<t t-esc="box_type"/>',
                    L: <t t-esc="box_l"/>,
                    W: <t t-esc="box_w"/>,
                    H: <t t-esc="box_h"/>,
                    dielineSvgUrl: '<t t-esc="dieline_svg_url"/>',
                    productId: <t t-esc="product.id if product else 0"/>,
                    productVariantId: <t t-esc="product_variant_id"/>,
                    productPrice: <t t-esc="product_price"/>,
                    orderArtworkJson: <t t-out="order_artwork_json or '{}'"/>,
                    readonlyMode: <t t-esc="'true' if readonly_mode else 'false'"/>
                };
            </script>

            <t t-set="options" t-value="{'defer_scripts': False}"/>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"/>
            <script src="/alltoppack_website/static/src/js/OrbitControls.js"/>
            <!-- Parser e geradores devem ser carregados antes do engine -->
            <script src="/alltoppack_website/static/src/js/dieline_parser.js?v=2"/>
            <script src="/alltoppack_website/static/src/js/dieline_engine.js?v=53"/>

            <script>
                (function () {
                    function syncQty() {
                        var src = document.getElementById('acc-qty-input');
                        var dst = document.getElementById('cart-qty-input');
                        if (src &amp;&amp; dst) dst.value = src.value;
                    }
                    document.addEventListener('DOMContentLoaded', function () {
                        syncQty();
                        var src = document.getElementById('acc-qty-input');
                        if (src) src.addEventListener('input', syncQty);

                        /* Card toggle */
                        document.querySelectorAll('[data-atp-toggle]').forEach(function (btn) {
                            btn.addEventListener('click', function () {
                                var card = btn.closest('.atp-scard');
                                var body = card.querySelector('.atp-scard-body');
                                var chevron = btn.querySelector('.atp-scard-chevron');
                                var open = card.classList.toggle('atp-scard--open');
                                body.style.display = open ? '' : 'none';
                                if (chevron) chevron.className = 'fa atp-scard-chevron fa-chevron-' + (open ? 'up' : 'down');
                            });
                        });

                        /* Quantity summary updater */
                        function updateQtySummary() {
                            var qtyEl = document.getElementById('acc-qty-input');
                            var varEl = document.getElementById('acc-variants-input');
                            var sumEl = document.getElementById('qty-summary');
                            if (!sumEl) return;
                            var qty = qtyEl ? (parseInt(qtyEl.value, 10) || 0) : 0;
                            var vrn = varEl ? (parseInt(varEl.value, 10) || 1) : 1;
                            sumEl.textContent = qty.toLocaleString() + ' pcs · ' + vrn + ' variant' + (vrn !== 1 ? 's' : '');
                        }
                        var qtyIn = document.getElementById('acc-qty-input');
                        var varIn = document.getElementById('acc-variants-input');
                        if (qtyIn) qtyIn.addEventListener('input', updateQtySummary);
                        if (varIn) varIn.addEventListener('input', updateQtySummary);
                        updateQtySummary();

                        /* Price tier click → set qty input + highlight */
                        document.querySelectorAll('.atp-tier').forEach(function (btn) {
                            btn.addEventListener('click', function () {
                                document.querySelectorAll('.atp-tier').forEach(function (b) { b.classList.remove('atp-tier--active'); });
                                btn.classList.add('atp-tier--active');
                                var qty = parseInt(btn.dataset.qty, 10);
                                var input = document.getElementById('acc-qty-input');
                                if (input) { input.value = qty; input.dispatchEvent(new Event('input')); }
                            });
                        });

                        /* Delivery option click → highlight */
                        document.querySelectorAll('.atp-delivery-option').forEach(function (opt) {
                            opt.addEventListener('click', function () {
                                document.querySelectorAll('.atp-delivery-option').forEach(function (o) { o.classList.remove('atp-delivery-option--active'); });
                                opt.classList.add('atp-delivery-option--active');
                            });
                        });

                        /* Order price updater — total e unit price reactivos à qty */
                        var _unitPrice = <t t-esc="product_price if product_price else 0"/>;
                        function updateOrderPrice() {
                            var qtyEl = document.getElementById('acc-qty-input');
                            var qty = qtyEl ? (parseInt(qtyEl.value, 10) || 0) : 0;
                            var totalEl = document.getElementById('atp-order-total');
                            var unitEl  = document.getElementById('atp-order-unit');
                            if (totalEl) {
                                var t = (_unitPrice * qty);
                                totalEl.textContent = '€' + t.toLocaleString('en', {minimumFractionDigits: 2, maximumFractionDigits: 2});
                            }
                            if (unitEl) {
                                unitEl.innerHTML = '€' + _unitPrice.toFixed(4) +
                                    '<span class="atp-order-unit-sep"> × </span>' +
                                    qty.toLocaleString() + ' pcs';
                            }
                        }
                        var qtyForPrice = document.getElementById('acc-qty-input');
                        if (qtyForPrice) qtyForPrice.addEventListener('input', updateOrderPrice);
                        updateOrderPrice();
                    });
                })();
            </script>

        </t>
    </template>

</odoo>
