<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- /produtos — lista de categorias raiz -->
    <template id="packaging_index" name="AllToPack — Produtos">
        <t t-call="website.layout">
            <div id="wrap" class="atp-packaging-page">
                <section class="atp-pkg-hero">
                    <div class="container text-center">
                        <h1 class="atp-pkg-hero__title">O que procura?</h1>
                    </div>
                </section>
                <section class="atp-pkg-grid-section">
                    <div class="container">
                        <div class="atp-pkg-grid">
                            <t t-foreach="categories" t-as="cat">
                                <a t-att-href="cat['url']" class="atp-pkg-card">
                                    <span class="atp-pkg-card__name">
                                        <t t-esc="cat['name']"/>
                                    </span>
                                    <i class="fa fa-chevron-right atp-pkg-card__arrow"/>
                                </a>
                            </t>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- /produtos/<slug> — lista de subcategorias -->
    <template id="packaging_subcategory" name="AllToPack — Subcategorias">
        <t t-call="website.layout">
            <div id="wrap" class="atp-packaging-page">
                <section class="atp-pkg-hero">
                    <div class="container text-center">
                        <a href="/produtos" class="atp-pkg-back">
                            <i class="fa fa-arrow-left"/> Voltar
                        </a>
                        <h1 class="atp-pkg-hero__title">
                            <t t-esc="parent.name"/>
                        </h1>
                    </div>
                </section>
                <section class="atp-pkg-grid-section">
                    <div class="container">
                        <div class="atp-pkg-grid">
                            <t t-foreach="categories" t-as="cat">
                                <a t-att-href="cat['url']" class="atp-pkg-card">
                                    <span class="atp-pkg-card__name">
                                        <t t-esc="cat['name']"/>
                                    </span>
                                    <i class="fa fa-chevron-right atp-pkg-card__arrow"/>
                                </a>
                            </t>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

</odoo>
